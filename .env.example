# =============================================================================
# Solomon Coffee — Environment Variables (copy to .env and fill in values)
# =============================================================================
# Never commit .env to git. Set secrets in your hosting dashboard for production.
# =============================================================================

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Public production URL used for social sharing / OG (do not use localhost here)
NEXT_PUBLIC_SITE_URL=https://shebascoffee.com
NODE_ENV=development

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-22
# Viewer/read token — required for SSR and for any browser Live preview
SANITY_API_READ_TOKEN=your_sanity_read_token
# Editor/write token — server-only; never expose as a browser token
SANITY_API_TOKEN=your_sanity_write_token

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# Staff admin portal sign-in (same Clerk app; path branding only): /{lang}/admin/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Stripe ---
# Use sk_live_ / pk_live_ (+ matching webhook) in production
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard endpoint must be: https://YOUR_DOMAIN/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Admin (server-only) ---
# Comma-separated emails that may open /admin. Must match a Clerk account email
# (primary OR any linked email on that user).
# Example: ADMIN_EMAIL=ops@shebascoffee.com,owner@gmail.com
# On Vercel/hosting: set ADMIN_EMAIL for Production (and Preview if needed).
# Do not rely on NEXT_PUBLIC_ADMIN_EMAIL — move that value into ADMIN_EMAIL.
ADMIN_EMAIL=admin@example.com

# Tax and shipping are configured in Admin > Checkout Settings.

# --- Company / public site info (fill real values before launch) ---
NEXT_PUBLIC_COMPANY_NAME=Sheba Cup Coffee
NEXT_PUBLIC_COMPANY_EMAIL=support@shebascoffee.com
NEXT_PUBLIC_COMPANY_PHONE=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_COMPANY_CITY=
NEXT_PUBLIC_SUPPORT_EMAIL=support@shebascoffee.com
NEXT_PUBLIC_SALES_EMAIL=sales@shebascoffee.com
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# --- Transactional email (Gmail OAuth2 via Nodemailer) ---
# Prefer a branded mailbox with SPF/DKIM on your domain for production.
SENDER_EMAIL_ADDRESS=orders@yourdomain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Feature switches (paid / optional modules) ---
# Employee roles, portal, and task delegation. Off by default — keep code, hide UI.
# NEXT_PUBLIC_EMPLOYEE_OPS_ENABLED=true

# Google Search Console site verification (optional)
# GOOGLE_SITE_VERIFICATION=

# --- Firebase Analytics (optional; not used for orders/profiles) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Loyalty (optional) ---
# REWARD_POINTS_THRESHOLD=3000
# LOYALTY_POINTS_THRESHOLD=
