# =============================================================================
# Solomon Coffee — Environment Variables (copy to .env and fill in values)
# =============================================================================
# Never commit .env to git. Set secrets in your hosting dashboard for production.
# =============================================================================

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-22
SANITY_API_READ_TOKEN=your_sanity_read_token
SANITY_API_TOKEN=your_sanity_write_token

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Admin (server-only — do NOT use NEXT_PUBLIC_ prefix) ---
# Comma-separated or bracketed: admin1@example.com,admin2@example.com
ADMIN_EMAIL=admin@example.com

# --- Tax (decimal rate, e.g. 0.08 = 8%) ---
NEXT_PUBLIC_TAX_AMOUNT=0

# --- Shipping (USD) ---
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=100
NEXT_PUBLIC_SHIPPING_FEE=10

# --- Company / public site info ---
NEXT_PUBLIC_COMPANY_NAME=Sheba's Coffee
NEXT_PUBLIC_COMPANY_EMAIL=support@example.com
NEXT_PUBLIC_COMPANY_PHONE=+1 (555) 123-4567

# --- Optional: Firebase, SSLCommerz, Gmail OAuth, loyalty ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# SSLCOMMERZ_STORE_ID=
# GOOGLE_CLIENT_ID=
# REWARD_POINTS_THRESHOLD=3000
